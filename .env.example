# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL — used by both backend and postgres service
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://filtrant:changeme@localhost:5432/filtrant

# App
ENV=production
LOG_LEVEL=INFO

# CORS — set to your public frontend URL in production
CORS_ORIGINS=http://localhost

# Frontend (Vite — only needed for local `npm run dev`, not Docker)
VITE_API_BASE_URL=http://localhost:8000
